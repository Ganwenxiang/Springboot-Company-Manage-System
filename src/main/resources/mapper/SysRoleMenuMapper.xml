<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.emps_project.mapper.SysRoleMenuMapper">

    <resultMap id="BaseResultMap" type="com.example.emps_project.entity.SysRoleMenu">
        <id column="id" property="id"/>
        <result column="role_id" property="roleId"/>
        <result column="menu_id" property="menuId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, role_id, menu_id, create_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_role_menu
        WHERE id = #{id}
    </select>

    <select id="selectByRoleId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_role_menu
        WHERE role_id = #{roleId}
        ORDER BY create_time DESC
    </select>

    <select id="selectByMenuId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_role_menu
        WHERE menu_id = #{menuId}
        ORDER BY create_time DESC
    </select>

    <insert id="insert" parameterType="com.example.emps_project.entity.SysRoleMenu" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_role_menu (role_id, menu_id)
        VALUES (#{roleId}, #{menuId})
    </insert>

    <insert id="insertBatch">
        INSERT INTO sys_role_menu (role_id, menu_id) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.roleId}, #{item.menuId})
        </foreach>
    </insert>

    <delete id="deleteById">
        DELETE FROM sys_role_menu WHERE id = #{id}
    </delete>

    <delete id="deleteByRoleId">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId}
    </delete>

    <delete id="deleteByMenuId">
        DELETE FROM sys_role_menu WHERE menu_id = #{menuId}
    </delete>

    <select id="countByRoleId" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM sys_role_menu WHERE role_id = #{roleId}
    </select>

</mapper>
