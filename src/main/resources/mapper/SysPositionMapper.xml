<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.emps_project.mapper.SysPositionMapper">

    <resultMap id="BaseResultMap" type="com.example.emps_project.entity.SysPosition">
        <id column="id" property="id"/>
        <result column="position_name" property="positionName"/>
        <result column="position_level" property="positionLevel"/>
        <result column="base_salary" property="baseSalary"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, position_name, position_level, base_salary, status, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_position
        WHERE id = #{id}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>,
               (SELECT COUNT(*) FROM sys_emp WHERE position_id = sys_position.id AND emp_status = 1) as emp_count
        FROM sys_position
        <where>
            <if test="positionName != null and positionName != ''">
                AND position_name LIKE CONCAT('%', #{positionName}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY position_level ASC, create_time DESC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_position
        WHERE status = 1
        ORDER BY position_level ASC, id ASC
    </select>

    <insert id="insert" parameterType="com.example.emps_project.entity.SysPosition" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_position (position_name, position_level, base_salary, status)
        VALUES (#{positionName}, #{positionLevel}, #{baseSalary}, #{status, jdbcType=TINYINT})
    </insert>

    <update id="update" parameterType="com.example.emps_project.entity.SysPosition">
        UPDATE sys_position
        <set>
            <if test="positionName != null and positionName != ''">position_name = #{positionName},</if>
            <if test="positionLevel != null">position_level = #{positionLevel},</if>
            <if test="baseSalary != null">base_salary = #{baseSalary},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_position WHERE id = #{id}
    </delete>

    <delete id="deleteByIds">
        DELETE FROM sys_position WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="countEmps" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM sys_emp
        WHERE position_id = #{positionId} AND emp_status = 1
    </select>

</mapper>
